{
  "id": null,
  "uid": "pharma-logs-v4",
  "title": "Pharma Logs",
  "tags": ["loki", "logs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "5s",

  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(level)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      },
      {
        "name": "search",
        "type": "textbox",
        "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },

  "panels": [

    {
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"file-logs\", service=~\"$service\", level=\"ERROR\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },

    {
      "type": "timeseries",
      "title": "Log Volume",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum(rate({job=\"file-logs\", service=~\"$service\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },

    {
      "type": "timeseries",
      "title": "Logs by Level",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (level) (rate({job=\"file-logs\", service=~\"$service\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 }
    },

    {
      "type": "logs",
      "title": "Live Logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"file-logs\", service=~\"$service\", level=~\"$level\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true
      },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 }
    },

    {
      "type": "logs",
      "title": "500 Errors",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"file-logs\", service=~\"$service\"} |= \" 500 \"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 10 }
    },

    {
      "type": "logs",
      "title": "Exceptions",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{job=\"file-logs\", service=~\"$service\"} |= \"Exception\"",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 10 }
    },

    {
      "type": "timeseries",
      "title": "Errors by Service",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({job=\"file-logs\", level=\"ERROR\"}[1m]))",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 8 }
    }

  ],

  "time": {
    "from": "now-15m",
    "to": "now"
  }
}
